{
  "name": "synod",
  "private": true,
  "description": "Unified monorepo for Synod server and client",
  "workspaces": [
    "server",
    "client",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:server && npm run build:client",
    "build:server": "npm run build --workspace @fyresmith/synod",
    "build:client": "npm run build:brat --workspace @fyresmith/synod-client",
    "verify": "npm run verify:server && npm run verify:client",
    "verify:server": "npm run verify --workspace @fyresmith/synod",
    "verify:client": "npm run verify --workspace @fyresmith/synod-client",
    "install-synod": "npm run install-synod --workspace @fyresmith/synod",
    "setup:assets": "node tools/synod-client/setup-assets.mjs",
    "artifacts:pin-client": "node tools/synod-client/pin-release.mjs",
    "artifacts:verify-client": "node tools/synod-client/verify-lock.mjs",
    "dev:vault": "node tools/dev-vault/materialize.mjs",
    "dev:client": "npm run dev --workspace @fyresmith/synod-client",
    "dev:run": "npm run dev:vault && npm run dev:run --workspace @fyresmith/synod",
    "dev:plugin-sync": "npm run dev:vault && npm run dev:plugin-sync --workspace @fyresmith/synod",
    "dev": "npm run dev:vault && npm run dev:client & npm run dev:run & npm run dev:plugin-sync; wait",
    "test": "npm run test --workspace @fyresmith/synod",
    "lint": "npm run lint --workspace @fyresmith/synod",
    "format:check": "npm run format:check --workspace @fyresmith/synod",
    "typecheck": "npm run typecheck --workspace @fyresmith/synod-client"
  },
  "engines": {
    "node": ">=20"
  }
}
