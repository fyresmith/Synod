{
  "name": "@fyresmith/synod",
  "version": "0.2.1",
  "type": "module",
  "license": "MIT",
  "description": "Collaborative Obsidian vault server",
  "main": "index.js",
  "files": [
    "bin",
    "cli",
    "assets",
    "lib",
    "server",
    "routes",
    "index.js",
    "README.md"
  ],
  "bin": {
    "synod": "bin/synod.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prepack": "npm run setup:assets && node scripts/sync-readme.mjs",
    "setup:assets": "node ../tools/synod-client/setup-assets.mjs",
    "start": "node index.js",
    "dev": "node --watch index.js",
    "dev:vault": "node ../tools/dev-vault/materialize.mjs",
    "dev:run": "npm run dev:vault && JWT_SECRET=synod-local-dev-jwt-secret-please-change-1234 VAULT_PATH=../.dev/template-vault PORT=3000 node index.js",
    "build": "npm run verify && npm pack --dry-run",
    "status": "node bin/synod.js status",
    "verify": "node scripts/verify.mjs",
    "install-synod": "node scripts/install-synod.mjs",
    "dev:plugin-sync": "npm run dev:vault && node bin/synod.js dev sync-plugin --watch --source ../client --vault-path ../.dev/template-vault",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "chokidar": "^3.6.0",
    "commander": "^13.1.0",
    "dotenv": "^16.4.5",
    "execa": "^9.6.0",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prompts": "^2.4.2",
    "socket.io": "^4.7.5",
    "which": "^6.0.0",
    "ws": "^8.17.1",
    "y-websocket": "^1.5.4",
    "yazl": "^2.5.1",
    "yjs": "^13.6.18"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "eslint": "^9.39.3",
    "globals": "^15.15.0",
    "prettier": "^3.8.1",
    "socket.io-client": "^4.8.3",
    "vitest": "^2.1.9"
  }
}
